# ============================================================
# Hyperush Panel — Docker altyapı ayarları
# ============================================================
# Google Client ID/Secret ve GitHub bilgileri BURAYA YAZILMAZ.
# Onlar ilk açılışta http://localhost:3000/setup ekranından girilir
# ve /data volume'unda saklanır.
# ============================================================

# Uygulama portu (host tarafı)
APP_PORT=3000

# Postgres bilgileri (container içi, dışarıya açık değil)
POSTGRES_USER=hyperush
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=hyperush

# ============================================================
# Cloudflare Tunnel (opsiyonel — reverse proxy için)
# ============================================================
# Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel
# "Cloudflared" seç → tunnel token'ı buraya yapıştır.
# Public hostname eklerken Service:  http://app:3000
#
# Başlatmak için:
#   docker compose --profile tunnel up -d
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================
# SMTP E-posta Ayarları (Opsiyonel — Bildirimler için)
# ============================================================
SMTP_HOST=mail.podhyperush.com
SMTP_PORT=587
SMTP_USER=noreply@podhyperush.com
SMTP_PASS=
